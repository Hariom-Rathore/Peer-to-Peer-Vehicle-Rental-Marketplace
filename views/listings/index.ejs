<% layout("/listings/layouts/boilerplate") %>
<body>
    <!-- <h3>all listings</h3> -->
    <!-- <form method="GET" action="/listings/new">
  
    </form> -->
<style>
  #filters {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 1.5rem;
    margin-top: 1.5rem;
    overflow-x: auto;
    padding-bottom: 0.5rem;
  }

  .filter {
    text-align: center;
    opacity: 0.7;
    min-width: 90px;
    flex: 0 0 auto;
  }

  .filter:hover {
    opacity: 1;
    cursor: pointer;
  }

  .filter-link {
    color: inherit;
  }

  .filter-link.active .filter {
    opacity: 1;
    color: #fe424d;
  }

  .tax-info{
    display: none;
  }

  .filter i {
    font-size: 1.2rem;
  }

.tax-toggle {
  border: 1px solid #cfcfcf;
  border-radius: 999px;
  min-height: 3rem;
  padding: 0.5rem 1rem;
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: 0.6rem;
  background-color: #fff;
  white-space: nowrap;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

.tax-toggle.active,
.tax-toggle:focus-within {
  border-color: #212529;
  box-shadow: 0 0 0 0.15rem rgba(33, 37, 41, 0.12);
}

.tax-toggle .form-check-input {
  float: none;
  margin-left: 0;
  margin-right: 0;
  margin-top: 0;
  cursor: pointer;
}

.tax-toggle .form-check-label {
  margin-bottom: 0;
  font-size: 0.9rem;
  cursor: pointer;
}

  .filter p {
    margin-top: 0.35rem;
    margin-bottom: 0;
    font-size: 0.8rem;
  }

  /* Mobile Responsive */
  @media (max-width: 575.98px) {
    #filters {
      gap: 0.75rem;
      margin-top: 1rem;
    }

    .filter {
      min-width: 70px;
    }

    .filter i {
      font-size: 0.9rem;
    }

    .filter p {
      font-size: 0.65rem;
    }

    .tax-toggle {
      min-height: 2.2rem;
      padding: 0.35rem 0.6rem;
      font-size: 0.8rem;
    }
  }

  @media (min-width: 576px) and (max-width: 767.98px) {
    #filters {
      gap: 1rem;
    }

    .filter {
      min-width: 80px;
    }

    .filter i {
      font-size: 1rem;
    }

    .filter p {
      font-size: 0.75rem;
    }
  }

  @media (min-width: 768px) and (max-width: 991.98px) {
    #filters {
      gap: 1.25rem;
    }
  }
</style>

  
    <div id="filters">
      <a href="/listings?category=all" class="filter-link <%= currentCategory === 'all' ? 'active' : '' %>">
        <div class="filter">
          <div><i class="fa-solid fa-fire"></i></div>
          <p>Trending</p>
        </div>
      </a>

      <a href="/listings?category=sedans" class="filter-link <%= currentCategory === 'sedans' ? 'active' : '' %>">
        <div class="filter">
          <div><i class="fa-solid fa-car-side"></i></div>
          <p>Sedans</p>
        </div>
      </a>

      <a href="/listings?category=suvs" class="filter-link <%= currentCategory === 'suvs' ? 'active' : '' %>">
        <div class="filter">
          <div><i class="fa-solid fa-truck-monster"></i></div>
          <p>SUVs</p>
        </div>
      </a>

      <a href="/listings?seats=4" class="filter-link <%= Number(currentSeats) === 4 ? 'active' : '' %>">
        <div class="filter">
          <div><i class="fa-solid fa-user-friends"></i></div>
          <p>4 Seater</p>
        </div>
      </a>

      <a href="/listings?seats=6" class="filter-link <%= Number(currentSeats) === 6 ? 'active' : '' %>">
        <div class="filter">
          <div><i class="fa-solid fa-users"></i></div>
          <p>6 Seater</p>
        </div>
      </a>

      <a href="/listings?seats=10" class="filter-link <%= Number(currentSeats) === 10 ? 'active' : '' %>">
        <div class="filter">
          <div><i class="fa-solid fa-people-roof"></i></div>
          <p>10 Seater</p>
        </div>
      </a>

      <a href="/listings?category=luxury" class="filter-link <%= currentCategory === 'luxury' ? 'active' : '' %>">
        <div class="filter">
          <div><i class="fa-solid fa-crown"></i></div>
          <p>Luxury</p>
        </div>
      </a>

      <a href="/listings?category=sports" class="filter-link <%= currentCategory === 'sports' ? 'active' : '' %>">
        <div class="filter">
          <div><i class="fa-solid fa-flag-checkered"></i></div>
          <p>Sports</p>
        </div>
      </a>

      <a href="/listings?category=offroad" class="filter-link <%= currentCategory === 'offroad' ? 'active' : '' %>">
        <div class="filter">
          <div><i class="fa-solid fa-hill-rockslide"></i></div>
          <p>Offroad</p>
        </div>
      </a>

      <a href="/listings?category=family" class="filter-link <%= currentCategory === 'family' ? 'active' : '' %>">
        <div class="filter">
          <div><i class="fa-solid fa-people-group"></i></div>
          <p>Family</p>
        </div>
      </a>

      <a href="/listings?category=vintage" class="filter-link <%= currentCategory === 'vintage' ? 'active' : '' %>">
        <div class="filter">
          <div><i class="fa-solid fa-clock-rotate-left"></i></div>
          <p>Vintage</p>
        </div>
      </a>

      <a href="/listings?category=winter" class="filter-link <%= currentCategory === 'winter' ? 'active' : '' %>">
        <div class="filter">
          <div><i class="fa-regular fa-snowflake"></i></div>
          <p>Winter</p>
        </div>
      </a>

      <div class="tax-toggle form-switch">
        <input 
        class="form-check-input"
        type="checkbox"
        role="switch"
        id="flewSwitchCheckDefault"
        />
        <label class="form-check-label" for="flewSwitchCheckDefault"
        >Display total after taxes</label>
      </div>

    </div>

    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
      <% if (!alllistings || alllistings.length === 0) { %>
        <div class="col-12 my-3">
          <div class="alert alert-warning">No cars found<% if (currentSearch && currentSearch.trim()) { %> for "<%= currentSearch %>"<% } %></div>
        </div>
      <% } %>
         <% for(let listing of alllistings){%>
            <% const listingImageUrl = (listing.image && listing.image.url) ? listing.image.url : (typeof listing.image === "string" ? listing.image : "https://images.pexels.com/photos/11129937/pexels-photo-11129937.jpeg"); %>
            <a href="/listings/<%=listing._id%>" class="listing-link">
    <div class="card col listing-card">
  <img src="<%= listingImageUrl %>" class="card-img-top" alt="car_image" style="height: 20rem" onerror="this.onerror=null;this.src='https://images.pexels.com/photos/11129937/pexels-photo-11129937.jpeg';"/>
  <div class="card-img-overlay"></div>
  <div class="card-body">
    <p class="card-text">
        <%=listing.title%> <br/>
      <%= listing.price != null ? listing.price.toLocaleString("en-IN") : "Price not available" %> /day
      <% if(listing.ratePerKm != null && listing.ratePerKm !== '') { %>
        <br/><small class="text-muted">&#8377; <%= listing.ratePerKm %> /km</small>
      <% } %>
       <i class="tax-info"> &nbsp:&nbsp;+18%GST</i>
    </p>
  </div>
</div>
   <%}%>
</div>
    
</a>

    
</body>

<script>
  const taxSwitch = document.getElementById("flewSwitchCheckDefault");
  const taxToggle = document.querySelector(".tax-toggle");

  if (taxSwitch) {
    taxSwitch.addEventListener("change", () => {
      const taxInfo = document.getElementsByClassName("tax-info");
      if (taxToggle) {
        taxToggle.classList.toggle("active", taxSwitch.checked);
      }
      for (const info of taxInfo) {
        info.style.display = taxSwitch.checked ? "inline" : "none";
      }
    });
  }
</script>
