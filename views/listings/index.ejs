<% layout("/listings/layouts/boilerplate") %>
<body>
    <!-- <h3>all listings</h3> -->
    <!-- <form method="GET" action="/listings/new">
  
    </form> -->
<style>
  #filters {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 1.5rem;
    margin-top: 1.5rem;
    overflow-x: auto;
    padding-bottom: 0.5rem;
  }

  .filter {
    text-align: center;
    opacity: 0.7;
    min-width: 90px;
    flex: 0 0 auto;
  }

  .filter:hover {
    opacity: 1;
    cursor: pointer;
  }

  .tax-info{
    display: none;
  }

  .filter i {
    font-size: 1.2rem;
  }

.tax-toggle {
  border: 1px solid #cfcfcf;
  border-radius: 999px;
  min-height: 3rem;
  padding: 0.5rem 1rem;
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: 0.6rem;
  background-color: #fff;
  white-space: nowrap;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

.tax-toggle.active,
.tax-toggle:focus-within {
  border-color: #212529;
  box-shadow: 0 0 0 0.15rem rgba(33, 37, 41, 0.12);
}

.tax-toggle .form-check-input {
  float: none;
  margin-left: 0;
  margin-right: 0;
  margin-top: 0;
  cursor: pointer;
}

.tax-toggle .form-check-label {
  margin-bottom: 0;
  font-size: 0.9rem;
  cursor: pointer;
}


  .filter p {
    margin-top: 0.35rem;
    margin-bottom: 0;
    font-size: 0.8rem;
  }
</style>

  
    <div id="filters">
      <div class="filter">
        <div><i class="fa-solid fa-fire"></i></div>
        <p>Trending</p>
      </div>

      <div class="filter">
        <div><i class="fa-solid fa-bed"></i></div>
        <p>Rooms</p>
      </div>

      <div class="filter">
        <div><i class="fa-solid fa-mountain-city"></i></div>
        <p>Iconic Cities</p>
      </div>

      <div class="filter">
        <div><i class="fa-solid fa-mountain"></i></div>
        <p>Mountains</p>
      </div>

      <div class="filter">
        <div><i class="fa-solid fa-fort-awesome"></i></div>
        <p>Castels</p>
      </div>

      <div class="filter">
        <div><i class="fa-solid fa-person-swimming"></i></div>
        <p>Amazing Pools</p>
      </div>

      <div class="filter">
        <div><i class="fa-solid fa-campground"></i></div>
        <p>Camping</p>
      </div>

      <div class="filter">
        <div><i class="fa-solid fa-cow"></i></div>
        <p>Farms</p>
      </div>

      <div class="filter">
        <div><i class="fa-solid fa-ship"></i></div>
        <p>Boats</p>
      </div>

      <div class="filter">
        <div><i class="fa-regular fa-snowflake"></i></div>
        <p>Arctic</p>
      </div>

      <div class="tax-toggle form-switch">
        <input 
        class="form-check-input"
        type="checkbox"
        role="switch"
        id="flewSwitchCheckDefault"
        />
        <label class="form-check-label" for="flewSwitchCheckDefault"
        >Display total after taxes</label>
      </div>

    </div>

    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
         <% for(let listing of alllistings){%>
            <a href="/listings/<%=listing._id%>" class="listing-link">
    <div class="card col listing-card">
  <img src="<%= listing.image?.url || listing.image || "https://images.pexels.com/photos/11129937/pexels-photo-11129937.jpeg" %>" class="card-img-top" alt="listing_image" style="height: 20rem"/>
  <div class="card-img-overlay"></div>
  <div class="card-body">
    <p class="card-text">
        <%=listing.title%> <br/>
       <%= listing.price != null ? listing.price.toLocaleString("en-IN") : "Price not available" %> /night
       <i class="tax-info"> &nbsp:&nbsp;+18%GST</i>
    </p>
  </div>
</div>
   <%}%>
</div>
    
</a>

    
</body>

<script>
  const taxSwitch = document.getElementById("flewSwitchCheckDefault");
  const taxToggle = document.querySelector(".tax-toggle");

  if (taxSwitch) {
    taxSwitch.addEventListener("change", () => {
      const taxInfo = document.getElementsByClassName("tax-info");
      if (taxToggle) {
        taxToggle.classList.toggle("active", taxSwitch.checked);
      }
      for (const info of taxInfo) {
        info.style.display = taxSwitch.checked ? "inline" : "none";
      }
    });
  }
</script>
