<% layout("/listings/layouts/boilerplate") %>
<body>
    <h3>all listings</h3>
    <!-- <form method="GET" action="/listings/new">
        
    </form> -->

    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1">
         <% for(let listing of alllistings){%>
            <a href="/listings/<%=listing._id%>" class="listing-link">
    <div class="card col" >
  <img src="<%= listing.image?.url || listing.image || "https://images.pexels.com/photos/11129937/pexels-photo-11129937.jpeg" %>" class="card-img-top" alt="listing_image" style="height: 20rem"/>
  <div class="card-img-overlay"></div>
  <div class="card-body">
    <p class="card-text">
        <%=listing.title%> <br/>
       <%= listing.price != null ? listing.price.toLocaleString("en-IN") : "Price not available" %> /night
    </p>
  </div>
</div>
   <%}%>
</div>
    
</a>

    
</body>
