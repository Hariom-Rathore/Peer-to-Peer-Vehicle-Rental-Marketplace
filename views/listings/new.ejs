<% layout("/listings/layouts/boilerplate") %>

<h2>Create a New Listing</h2>

<% if (errorMsg) { %>
    <div class="alert alert-danger" role="alert"><%= errorMsg %></div>
<% } %>

<form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
    <div class="row">
        <div class="col-8 offset-2">
            <div class="mb-3">
                <label for="title" class="form-label">Title</label>
                <input id="title" name="listing[title]" placeholder="Add a catchy title" type="text" class="form-control" required value="<%= listing && listing.title ? listing.title : "" %>">
                <div class="invalid-feedback">Please enter a title.</div>
            </div>

            <div class="mb-3">
                <label for="description" class="form-label">Description</label>
                <input id="description" name="listing[description]" placeholder="Enter description" type="text" class="form-control" required value="<%= listing && listing.description ? listing.description : "" %>">
                <div class="invalid-feedback">Please enter a description.</div>
            </div>



             <div class="mb-3">
                <label for="image" class="form-label">Upload listing Image</label>
                <input id="image" name="listing[image]" placeholder="Image url" type="file" class="form-control">
                required
                
            </div> 

            <div class="row">
                <div class="mb-3 col-md-4">
                    <label for="price" class="form-label">Price</label>
                    <input id="price" name="listing[price]" placeholder="Enter integer price (e.g. 1200)" type="text" class="form-control" required value="<%= listing && listing.price !== undefined && listing.price !== null ? listing.price : "" %>">
                    <div class="invalid-feedback">Please enter a valid price.</div>
                </div>

                <div class="mb-3 col-md-8">
                    <label for="country" class="form-label">Country</label>
                    <input id="country" name="listing[country]" placeholder="India" type="text" class="form-control" required value="<%= listing && listing.country ? listing.country : "" %>">
                    <div class="invalid-feedback">Please enter a country.</div>
                </div>
            </div>

            <div class="mb-3">
                <label for="location" class="form-label">Location</label>
                <input id="location" name="listing[location]" placeholder="Enter location" type="text" class="form-control" required value="<%= listing && listing.location ? listing.location : "" %>">
                <div class="invalid-feedback">Please enter a location.</div>
            </div>

            <button class="btn btn-dark">Add</button>
        </div>
    </div>
</form>

<br>
