<!-- Autocomplete suggestions container -->
<div id="search-suggestions" style="position:relative; max-width:600px; margin:0 auto;">
  <div id="suggestions-list" class="list-group" style="position:absolute; z-index:2000; width:100%; display:none;
    max-height:300px; overflow:auto;
  "></div>
</div>

<script>
  (function(){
    const input = document.getElementById('nav-search-input');
    const suggestionsList = document.getElementById('suggestions-list');
    const form = input ? input.closest('form') : null;
    let timeout = null;
    let selected = -1;

    if (!input || !suggestionsList || !form) return;

    function clearSuggestions(){
      suggestionsList.innerHTML = '';
      suggestionsList.style.display = 'none';
      selected = -1;
    }

    function renderSuggestions(items){
      suggestionsList.innerHTML = '';
      if (!items || items.length === 0) { clearSuggestions(); return; }
      items.forEach((it, idx)=>{
        const a = document.createElement('a');
        a.className = 'list-group-item list-group-item-action';
        a.href = '#';
        a.dataset.title = it.title;
        a.dataset.id = it.id;
        a.innerHTML = `<div class="d-flex w-100 justify-content-between"><h6 class="mb-1">${it.title}</h6><small>${it.price != null ? it.price : ''}</small></div>`;
        a.addEventListener('click', (e)=>{
          e.preventDefault();
          input.value = a.dataset.title || '';
          clearSuggestions();
          form.submit();
        });
        suggestionsList.appendChild(a);
      });
      suggestionsList.style.display = 'block';
    }

    input.addEventListener('input', (e)=>{
      const q = input.value.trim();
      if (timeout) clearTimeout(timeout);
      if (!q) { clearSuggestions(); return; }
      timeout = setTimeout(async ()=>{
        try{
          const res = await fetch('/listings/autocomplete?q=' + encodeURIComponent(q));
          if (!res.ok) { clearSuggestions(); return; }
          const data = await res.json();
          renderSuggestions(data);
        }catch(err){
          clearSuggestions();
        }
      }, 200);
    });

    // keyboard navigation
    input.addEventListener('keydown', (e)=>{
      const items = suggestionsList.querySelectorAll('.list-group-item');
      if (!items.length) return;
      if (e.key === 'ArrowDown'){
        e.preventDefault(); selected = Math.min(selected+1, items.length-1);
        items.forEach((el,i)=> el.classList.toggle('active', i===selected));
      } else if (e.key === 'ArrowUp'){
        e.preventDefault(); selected = Math.max(selected-1, 0);
        items.forEach((el,i)=> el.classList.toggle('active', i===selected));
      } else if (e.key === 'Enter'){
        const active = items[selected];
        if (active){
          e.preventDefault();
          input.value = active.dataset.title || '';
          clearSuggestions();
          form.submit();
        }
      } else if (e.key === 'Escape'){
        clearSuggestions();
      }
    });

    // click outside closes
    document.addEventListener('click', (e)=>{
      if (!suggestionsList.contains(e.target) && e.target !== input){
        clearSuggestions();
      }
    });
  })();
</script>